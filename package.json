{
  "name": "armath-makerspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build --webpack",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm content:qa",
    "content:qa": "node scripts/content-qa.mjs",
    "dev": "next dev --webpack",
    "lint": "eslint .",
    "start": "next start",
    "test": "node --experimental-strip-types --test --test-concurrency=1 tests/api/admin-auth-core.test.ts tests/api/submission-core.test.ts tests/api/attendance-event-core.test.ts tests/api/attendance-device-auth.test.ts tests/e2e/admin-client-journey.test.ts",
    "test:api": "node --experimental-strip-types --test --test-concurrency=1 tests/api/admin-auth-core.test.ts tests/api/submission-core.test.ts tests/api/attendance-event-core.test.ts tests/api/attendance-device-auth.test.ts",
    "test:e2e": "node --experimental-strip-types --test --test-concurrency=1 tests/e2e/admin-client-journey.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "1.4.0",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@supabase/supabase-js": "2.105.3",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "contentlayer2": "^0.5.8",
    "framer-motion": "12.38.0",
    "lucide-react": "1.14.0",
    "next": "16.2.4",
    "next-contentlayer2": "^0.5.8",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "resend": "6.12.2",
    "tailwind-merge": "3.5.0",
    "tailwindcss-animate": "1.0.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.4",
    "postcss": "8.5.14",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "contentlayer2",
      "esbuild",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ]
